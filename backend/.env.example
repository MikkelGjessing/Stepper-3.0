# ─────────────────────────────────────────────────────────────────────────────
# Ask Stepper – Backend environment variables
#
# Copy this file to .env and fill in real values before starting the server.
# NEVER commit a .env file with real credentials.
# ─────────────────────────────────────────────────────────────────────────────

# Port the backend HTTP server listens on (default: 3001)
PORT=3001

# ── LLM provider ─────────────────────────────────────────────────────────────
# API key for the language model provider (e.g. OpenAI, Azure OpenAI, …)
# REQUIRED. Keep this secret – it must NOT be placed in the extension.
LLM_API_KEY=your_llm_api_key_here

# Chat completion endpoint (e.g. https://api.openai.com/v1/chat/completions)
LLM_ENDPOINT=https://api.openai.com/v1/chat/completions

# Model identifier (e.g. gpt-4o, gpt-4-turbo, gpt-3.5-turbo)
LLM_MODEL=gpt-4o

# ── Knowledge base / ServiceNow ───────────────────────────────────────────────
# Base URL for the ServiceNow Knowledge Management API
SN_BASE_URL=https://your-instance.service-now.com/api/sn_km_api/knowledge/articles

# ServiceNow credentials used by the backend for KB retrieval
SN_USERNAME=your_servicenow_username
SN_PASSWORD=your_servicenow_password

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (leave blank to allow all)
# Example: chrome-extension://abcdefghijklmnop,https://example.com
ALLOWED_ORIGINS=
